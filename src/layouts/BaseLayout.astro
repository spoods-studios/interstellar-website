---
import '../styles/global.css';
import { DISCORD_INVITE_URL, SITE_NAME, SITE_TAGLINE, OG_DEFAULT } from '../lib/site.mjs';

export interface Props {
  title: string;
  description?: string;
  ogType?: 'article' | 'website';
  ogImage?: { src: string; width: number; height: number; alt: string };
  publishedTime?: string;
}

const { title, description, ogType, ogImage, publishedTime } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
// BASE_URL has no guaranteed trailing slash (astro.config.mjs's configured
// base ends with no slash), so appending route segments directly would glue
// them onto the last path component instead of separating with '/'.
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

// D-50: every page emits the full block -- the 404 included -- so the
// description falls back to the tagline rather than being omitted.
const metaDescription = description ?? SITE_TAGLINE;
const resolvedType = ogType ?? 'website';
const card = ogImage ?? { ...OG_DEFAULT, src: `${base}${OG_DEFAULT.file}` };
// card.src already carries the base in both branches, so new URL() composes
// the absolute form without any manual slash arithmetic (SITE-02: the host
// comes from astro.config.mjs's `site`, never a literal).
const ogImageUrl = new URL(card.src, Astro.site).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {/*
      Values below use plain Astro {expr} attribute interpolation, which escapes
      attribute context correctly (" -> &quot;, & -> &amp;). Deliberately NOT
      src/lib/escape-html.ts: that helper leaves quotes unescaped (an
      attribute-breakout hazard here) and would double-escape ampersands. The
      WR-01/WR-02 findings that introduced it applied to set:html on titles --
      the opposite context, and they do not generalize to attributes.
      og:title carries the bare title prop: <title> has no site-name suffix, so
      appending SITE_NAME would visibly double the brand next to og:site_name.
    */}
    <meta property="og:type" content={resolvedType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(card.width)} />
    <meta property="og:image:height" content={String(card.height)} />
    <meta property="og:image:alt" content={card.alt} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#1d5fae" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header>
      <a class="wordmark" href={base}>Interstellar Engine</a>
      <nav>
        <a href={base}>Devblog</a>
        <a href={`${base}technical/`}>Technical</a>
        <a href={`${base}how-its-made/`}>How It's Made</a>
        <a href={`${base}roadmap/`}>Roadmap</a>
        <a href={DISCORD_INVITE_URL} target="_blank" rel="noopener noreferrer">Discord</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      {/* Plan 03-02 inserts `<a …>RSS</a> · ` before the Discord link -- the
          separator structure is shaped so that stays a pure insertion. */}
      <p>© 2026 Spoods Studios · <a href={DISCORD_INVITE_URL} target="_blank" rel="noopener noreferrer">Join the Discord</a></p>
    </footer>
  </body>
</html>
