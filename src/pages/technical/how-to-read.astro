---
// D-32: the legend's collection id ("how-to-read") has no milestone segment,
// so it does not fit the dynamic [milestone]/[slug] route -- a dedicated
// static route reads more clearly than special-casing that route for one
// entry. Renders through the same PostLayout, one page.
import { getCollection, render } from 'astro:content';
import { assertNonEmpty, isVisible } from '../../lib/content-guards';
import { describeBody } from '../../lib/describe-entry';
import { titleFromH1 } from '../../lib/title-from-h1';
import PostLayout from '../../layouts/PostLayout.astro';

const technicalEntries = assertNonEmpty(await getCollection('technical'), 'technical').filter(isVisible);
const entry = technicalEntries.find((e) => e.id === 'how-to-read');
if (!entry) {
  throw new Error("technical collection has no visible 'how-to-read' entry");
}
const { Content, headings } = await render(entry);
const title = titleFromH1(entry.body, entry.id);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const backLink = { href: `${base}technical/`, label: 'Back to the technical index' };

// The legend is a standing reference page, not one of the 55 deep-dives, so
// it is a `website` rather than an `article`.
const description = describeBody(entry.body, entry.id);
---

<PostLayout
  title={title}
  headings={headings}
  backLink={backLink}
  description={description}
  ogType="website"
>
  <Content />
</PostLayout>
