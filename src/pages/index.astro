---
// D-13: the site root IS the announcement archive -- flat reverse-chronological
// list of every visible devlog entry. Querying only the `devlog` collection is
// the whole of CONT-03's structural exclusion (T-02-03/D-26/D-31): the two
// standalone pages live in the separate `pages` collection, so no filter is
// needed (or written) to keep them out.
import { getCollection } from 'astro:content';
import { assertNonEmpty, isVisible } from '../lib/content-guards';
import { titleFromH1 } from '../lib/title-from-h1';
import { entryDate, formatDate, sortEntriesNewestFirst } from '../lib/devlog-meta';
import { escapeHtml } from '../lib/escape-html';
import { SITE_TAGLINE } from '../lib/site.mjs';
import BaseLayout from '../layouts/BaseLayout.astro';

const allEntries = assertNonEmpty(await getCollection('devlog'), 'devlog');
const visible = allEntries.filter(isVisible);

// D-45: the archive, the post route's prev/next chain and the feed all run
// this one expression -- the archive and the post route must never disagree on
// order, and the shared comparator's id tie-break makes that structural rather
// than an accident of the nine announcements carrying nine distinct dates.
const sorted = sortEntriesNewestFirst(visible);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const posts = sorted.map((entry) => {
  // D-01: title falls back to the manifesto's first H1 when frontmatter title is absent.
  const title = entry.data.title ?? titleFromH1(entry.body, entry.id);
  const date = entryDate(entry);
  // D-11: milestone tag + date; the manifesto has no milestone and renders the date alone.
  const meta = entry.data.milestone
    ? `${entry.data.milestone} · ${formatDate(date)}`
    : formatDate(date);

  return { href: `${base}devlog/${entry.id}/`, title, meta };
});

// D-16: developer-approved verbatim, 2026-07-22 -- plain interpolation since
// this is developer-authored copy, not content-derived HTML. The string has
// exactly one home in the repo (src/lib/site.mjs), shared by this paragraph,
// the homepage's og:description below and the feed channel copy, so it can
// never be re-typed into three copies that drift apart.
const oneLiner = SITE_TAGLINE;
---

<BaseLayout title="Interstellar Engine — Devblog" description={SITE_TAGLINE}>
  <p>{oneLiner}</p>
  <ul>
    {posts.map((post) => (
      <li>
        <a href={post.href} set:html={escapeHtml(post.title)} />
        <p class="meta">{post.meta}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
