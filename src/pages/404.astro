---
import BaseLayout from '../layouts/BaseLayout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

// D-19 body copy, now with one home in the file: the paragraph renders it and
// the embed describes the page with it. No 404-specific marketing copy exists
// or should -- the page's own words are the description.
const notFoundCopy =
  "The page you're looking for doesn't exist — it may have moved or the link is out of date.";
---

<BaseLayout title="Page not found" description={notFoundCopy}>
  <h1>Page not found.</h1>
  <p>{notFoundCopy}</p>
  <p><a href={base}>&larr; Back home</a></p>
</BaseLayout>
