---
// D-13's URL shape: one static page per visible devlog entry at
// /devlog/<entry id>/ (the id already carries the date, from
// content.config.ts's generateId). Sorted the same way as the archive
// index (Plan 05) so prev/next and the homepage list can never disagree.
import { getCollection, render } from 'astro:content';
import { assertNonEmpty, isVisible } from '../../lib/content-guards';
import { entryDate, entryTitle, formatDate, sortEntriesNewestFirst } from '../../lib/devlog-meta';
import { describeBody } from '../../lib/describe-entry';
import { titleFromH1 } from '../../lib/title-from-h1';
import { sortByPhaseNumber } from '../../lib/phase-sort';
import { normalizeMilestone } from '../../lib/milestone-key';
import { heroFor } from '../../lib/hero-assets';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allEntries = assertNonEmpty(await getCollection('devlog'), 'devlog');
  const visible = allEntries.filter(isVisible);
  // D-35's other direction: each announcement lists its milestone's
  // deep-dives, generated from the collection query (isVisible-filtered --
  // T-02-03, a drafted deep-dive must not leak into this chrome list).
  const technicalEntries = assertNonEmpty(await getCollection('technical'), 'technical').filter(isVisible);

  // Newest first -- the one shared ordering expression the archive, this
  // route's prev/next chain and the feed all consume.
  const sorted = sortEntriesNewestFirst(visible);

  return sorted.map((entry, index) => {
    const deepDives = entry.data.milestone
      ? sortByPhaseNumber(
          technicalEntries.filter((t) => {
            if (t.id === 'how-to-read') return false;
            return normalizeMilestone(t.id.split('/')[0]) === normalizeMilestone(entry.data.milestone);
          })
        )
      : [];

    return {
      params: { slug: entry.id },
      props: {
        entry,
        olderEntry: sorted[index + 1],
        newerEntry: sorted[index - 1],
        deepDives,
      },
    };
  });
}

const { entry, olderEntry, newerEntry, deepDives } = Astro.props;
const { Content, headings } = await render(entry);

const title = entryTitle(entry);
const date = entryDate(entry);
// D-11: milestone tag + date, middot-separated; the manifesto has no
// milestone and renders the date alone -- never fabricate one.
const meta = entry.data.milestone
  ? `${entry.data.milestone} · ${formatDate(date)}`
  : formatDate(date);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const prevNext = {
  prev: olderEntry
    ? { href: `${base}devlog/${olderEntry.id}/`, label: entryTitle(olderEntry) }
    : undefined,
  next: newerEntry
    ? { href: `${base}devlog/${newerEntry.id}/`, label: entryTitle(newerEntry) }
    : undefined,
};

const backLink = { href: base, label: 'Back to devblog' };

// D-51: the description comes from the entry's own body. Announcements carry
// real dates, so article:published_time is legitimate here (deep-dives, which
// have no date per D-33, must not get a fabricated one).
const description = describeBody(entry.body, entry.id);

// D-48: the two announcements that carry a real engine plot in their body embed
// that plot; everywhere else hero is null and BaseLayout applies the default
// card, so exactly one image is ever emitted. Alt is the post's own title --
// the site layer cannot interpret a plot well enough to describe it (UI-SPEC).
const hero = heroFor(entry);
const ogImage = hero
  ? { src: hero.src, width: hero.width, height: hero.height, alt: title }
  : undefined;
---

<PostLayout
  title={title}
  meta={meta}
  headings={headings}
  prevNext={prevNext}
  backLink={backLink}
  description={description}
  ogType="article"
  ogImage={ogImage}
  publishedTime={date.toISOString()}
>
  <Content />
  {deepDives.length > 0 && (
    <>
      <h2>Technical deep-dives for this milestone:</h2>
      <ul>
        {deepDives.map((d) => (
          <li><a href={`${base}technical/${d.id}/`}>{titleFromH1(d.body, d.id)}</a></li>
        ))}
      </ul>
    </>
  )}
</PostLayout>
